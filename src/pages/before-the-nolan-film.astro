      <a class="nav-item" href="/after-the-iliad">After the Iliad</a>
      <a class="nav-item" href="/retellings">Modern Retellings</a>
      <a class="nav-item" href="/podcasts">Podcasts</a>
      <a class="nav-item" href="/characters">Character Reference</a>
      <a class="nav-item" href="/battle-and-geography">Battle &amp; Geography</a>
      <a class="nav-item" href="/synopsis">Book-by-Book Synopsis</a>
      <a class="nav-item" href="/gods">The Gods</a>
      <a class="nav-item" href="/glossary">Key Terms Glossary</a>
      <a class="nav-item" href="/bronze-age-collapse">Bronze Age Collapse</a>
      <a class="nav-item" href="/major-battles">Major Battles</a>
