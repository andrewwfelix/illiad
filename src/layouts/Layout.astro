---
import SEO from '../components/SEO.astro';
const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const nav = [
  { href: '/before-the-nolan-film', label: 'Before the Nolan Film', nolan: true },
  { href: '/', label: 'Introduction' },
  { href: '/themes', label: 'Themes' },
  { href: '/translations', label: 'Choosing a Translation' },
  { href: '/how-to-read', label: 'How to Read' },
  { href: '/bronze-age-world', label: 'Bronze Age World' },
  { href: '/mythology', label: 'Mythology' },
  { href: '/ancient-historians', label: 'Ancient Historians' },
  { href: '/modern-scholars', label: 'Modern Scholars' },
  { href: '/after-the-iliad', label: 'After the Iliad' },
  { href: '/retellings', label: 'Modern Retellings' },
  { href: '/podcasts', label: 'Podcasts' },
  { href: '/characters', label: 'Character Reference' },
  { href: '/battle-and-geography', label: 'Battle & Geography' },
  { href: '/synopsis', label: 'Book-by-Book Synopsis' },
  { href: '/gods', label: 'The Gods' },
  { href: '/glossary', label: 'Key Terms Glossary' },
  { href: '/bronze-age-collapse', label: 'Bronze Age Collapse' },
  { href: '/major-battles', label: 'Major Battles' },
  { href: '/weapons-and-armor', label: 'Weapons & Armor' },
  { href: '/gift-guide', label: 'Gift Guide' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO title={title} description={description} canonical={canonicalURL.href} />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Upright:ital,wght@0,400;0,600;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EKTNHX1JX4"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EKTNHX1JX4');
  </script>
</head>
<body>
  <nav id="sidebar">
    <div id="sidebar-header">
      <button id="hamburger" aria-label="Close menu">✕</button>
      <h1>THE COMPLETE GUIDE TO READING THE ILIAD</h1>
      <p>Everything before you open the book</p>
    </div>
    <div id="nav">
      {nav.map(item => (
        <a
          href={item.href}
          class={`nav-item${item.nolan ? ' nolan-nav' : ''}${Astro.url.pathname === item.href ? ' active' : ''}`}
        >{item.label}</a>
      ))}
      <a class="nav-item" href="https://readingtheodyssey.com" target="_blank" rel="noopener">Reading the Odyssey</a>
    </div>
  </nav>

  <div id="mobile-topbar">
    <button id="mobile-menu-btn" aria-label="Open menu">☰</button>
    <span id="mobile-title">The Complete Guide to Reading the Iliad</span>
  </div>

  <div id="sidebar-overlay"></div>

  <main id="main">
    <div id="content-scroll">
      <slot />
    </div>
  </main>

  <script>
    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      sidebar.classList.toggle('open');
      overlay.classList.toggle('active');
    }
    document.getElementById('hamburger').addEventListener('click', toggleSidebar);
    document.getElementById('mobile-menu-btn').addEventListener('click', toggleSidebar);
    document.getElementById('sidebar-overlay').addEventListener('click', toggleSidebar);
    document.querySelectorAll('#nav a').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 768) toggleSidebar();
      });
    });
  </script>
</body>
</html>
